{
  "name": "@drs/mcp-server",
  "version": "0.1.0",
  "description": "DRS MCP server middleware — extracts and verifies X-DRS-Bundle headers",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OkeyAmy/DRS",
    "directory": "packages/drs-mcp-server"
  },
  "keywords": ["drs", "mcp", "server", "middleware", "verification"],
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
