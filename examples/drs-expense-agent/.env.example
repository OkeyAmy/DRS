# .env.example — copy to .env and fill in your values
# Get a Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# URL of the running drs-verify service (started by docker-compose up -d)
DRS_VERIFY_URL=http://localhost:8080

# Port the expense tool server listens on (default 3001)
TOOL_SERVER_PORT=3001

# URL of the expense tool server (used by the agent)
TOOL_SERVER_URL=http://localhost:3001
