      "parent": {
        "max_cost_usd": 10,
        "pii_access": false,
        "write_access": false
      },
      "child": {
        "max_cost_usd": 10,
        "pii_access": false,
        "write_access": false
      }
    },
    {
      "id": "pol-pass-002-tighter-cost",
      "parent": {
        "max_cost_usd": 10
      },
      "child": {
        "max_cost_usd": 5
      }
    },
    {
      "id": "pol-pass-003-subset-tools",
      "parent": {
        "allowed_tools": [
          "web_search",
          "file_read",
          "summarise"
        ]
      },
      "child": {
        "allowed_tools": [
          "web_search"
        ]
      }
    },
    {
      "id": "pol-pass-004-child-adds-restriction",
      "parent": {
        "max_cost_usd": 50
      },
      "child": {
        "max_cost_usd": 10,
        "pii_access": false
      }
    },
    {
