        "max_calls": 100
      },
      "child": {
        "max_calls": 50
      }
    },
    {
      "id": "pol-pass-007-subset-resources",
      "parent": {
        "allowed_resources": [
          "mcp://tools/a",
          "mcp://tools/b"
        ]
      },
      "child": {
        "allowed_resources": [
          "mcp://tools/a"
        ]
      }
    },
    {
      "id": "pol-pass-008-subset-data-classes",
      "parent": {
        "allowed_data_classes": [
          "public",
          "internal"
        ]
      },
      "child": {
        "allowed_data_classes": [
          "public"
        ]
