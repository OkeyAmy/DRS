# ── Rust (drs-core) ───────────────────────────────────────────────────────────
target/
**/*.rs.bk
*.pdb
**/mutants.out*/

# ── Go (drs-verify) ───────────────────────────────────────────────────────────
# Compiled binaries
drs-verify/bin/
drs-verify/drs-verify

# ── TypeScript (drs-sdk) ──────────────────────────────────────────────────────
drs-sdk/node_modules/
drs-sdk/dist/
drs-sdk/.tsbuildinfo
drs-sdk/coverage/

# ── Editor / OS ───────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Secrets / credentials (never commit these) ────────────────────────────────
*.key
*.pem
*.env
.env.*
!.env.example

# ── DR Store runtime data (Tier 1 filesystem store) ──────────────────────────
dr-store/

# ── Project files excluded from repo ─────────────────────────────────────────
reddit_post.md
CLAUDE.md
docs-site/book/

drs-verify/coverage.out
drs-core/pkg/
.claude
docs/superpowers/
docs/technical_v2.md


drs-verify/drs-verify-bin

# ── Additional TypeScript / Node / tooling ignores ────────────────────────────
# Node modules (root and any workspace packages)
node_modules/
**/node_modules/

# Build / output folders
dist/
build/
out/
lib/

# TypeScript buildinfo
**/*.tsbuildinfo

# Common caches
.cache/
.parcel-cache/
.turbo/
.next/
.vercel/

# Coverage and test output
coverage/
.nyc_output/
coverage/lcov.info

# Logs
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Debug and lock files (ignore package-lock if using pnpm, keep pnpm-lock.yaml if you commit it)
package-lock.json

# Editor and tooling caches
.eslintcache
.idea/
.vscode/

# Environment locals (next.js and other frameworks)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Misc
.serverless/
*.log

